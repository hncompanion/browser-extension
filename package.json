{
  "type": "module",
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.66",
    "@ai-sdk/google": "^3.0.58",
    "@ai-sdk/openai": "^3.0.50",
    "@google/generative-ai": "^0.24.1",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.3.2",
    "@tailwindplus/elements": "^1.0.22",
    "ai": "^6.0.146",
    "dompurify": "^3.4.11",
    "jsdom": "^29.1.1",
    "marked": "^17.0.6",
    "tailwindcss": "^4.3.2",
    "wxt": "^0.20.27"
  },
  "scripts": {
    "dev": "NODE_OPTIONS=\"--localstorage-file=$(pwd)/.wxt/node-localstorage\" wxt",
    "dev:firefox": "NODE_OPTIONS=\"--localstorage-file=$(pwd)/.wxt/node-localstorage\" wxt -b firefox",
    "build": "NODE_OPTIONS=\"--localstorage-file=$(pwd)/.wxt/node-localstorage\" wxt build",
    "build:firefox": "NODE_OPTIONS=\"--localstorage-file=$(pwd)/.wxt/node-localstorage\" wxt build -b firefox --mv3",
    "zip": "NODE_OPTIONS=\"--localstorage-file=$(pwd)/.wxt/node-localstorage\" wxt zip",
    "zip:firefox": "NODE_OPTIONS=\"--localstorage-file=$(pwd)/.wxt/node-localstorage\" wxt zip -b firefox --mv3",
    "test": "node --test 'tests/**/*.test.js'",
    "providers:check": "node scripts/providers.js --check"
  },
  "packageManager": "pnpm@11.7.0"
}
